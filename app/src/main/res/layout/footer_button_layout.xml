<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/footer_notifications"
        style="@style/FooterActionButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_notifications"
            app:tint="#FF6B6B"
            android:contentDescription="@string/content_desc_notifications_icon"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notifications_title"
            android:gravity="center"
            android:singleLine="true"
            android:maxLines="1"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footer_settings"
        style="@style/FooterActionButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_settings_white"
            app:tint="@android:color/white"
            android:contentDescription="@string/content_desc_settings_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:gravity="center"
            android:singleLine="true"
            android:maxLines="1"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footer_device"
        style="@style/FooterActionButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_device"
            app:tint="@android:color/white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/devices_title"
            android:gravity="center"
            android:singleLine="true"
            android:maxLines="1"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footer_create"
        style="@style/FooterActionButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_create"
            app:tint="@android:color/white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/create_action"
            android:singleLine="true"
            android:maxLines="1"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footer_delete"
        style="@style/FooterActionButton"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_block"
            app:tint="@android:color/white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/delete_action"
            android:gravity="center"
            android:singleLine="true"
            android:maxLines="1"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

</LinearLayout>