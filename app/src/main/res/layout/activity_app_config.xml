<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_app_config"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#071427"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#071427"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/app_config_title"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_control_center_title"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/settings_control_center_subtitle"
                    android:textColor="#9FB3C8"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/open_manual_btn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:text="@string/open_manual_action"
                    android:textAllCaps="false"
                    android:textColor="#071427"
                    android:textStyle="bold"
                    app:backgroundTint="#3DDC84"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_apps"
                    app:iconTint="#071427" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/general_settings_title"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_connection_subtitle"
                    android:textColor="#9FB3C8"
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/SantiWayTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/server_ipv4_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/server_ip_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:enabled="false"
                        android:focusable="false"
                        android:longClickable="false"
                        android:textColor="@android:color/white"
                        android:textColorHint="#9FB3C8" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/SantiWayTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/api_key_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/api_key_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:enabled="false"
                        android:focusable="false"
                        android:longClickable="false"
                        android:textColor="@android:color/white"
                        android:textColorHint="#9FB3C8" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/SantiWayTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/device_name_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/device_scanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@android:color/white"
                        android:textColorHint="#9FB3C8" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/SantiWayTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/map_points_count_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/map_point_limit_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@android:color/white"
                        android:textColorHint="#9FB3C8" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_navigation_title"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/language_label"
                    android:textColor="#C5D2E0"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_field">

                    <Spinner
                        android:id="@+id/language_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"
                        android:paddingEnd="44dp"
                        android:popupBackground="#172A46" />

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:text="@string/spinner_arrow"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/geolocation_protocol_label"
                    android:textColor="#C5D2E0"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_settings_field">

                    <Spinner
                        android:id="@+id/protocol_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"
                        android:paddingEnd="44dp"
                        android:popupBackground="#172A46" />

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:text="@string/spinner_arrow"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_location_title"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/target_detection_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/target_detection_label"
                    android:textColor="@android:color/white"
                    android:thumbTint="@android:color/white"
                    android:trackTint="#3DDC84"
                    android:visibility="gone" />

                <Switch
                    android:id="@+id/static_location_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/use_static_coordinates"
                    android:textColor="@android:color/white"
                    android:thumbTint="@android:color/white"
                    android:trackTint="#3DDC84" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/SantiWayTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/latitude_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/static_latitude_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@android:color/white"
                        android:textColorHint="#9FB3C8" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/SantiWayTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/longitude_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/static_longitude_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@android:color/white"
                        android:textColorHint="#9FB3C8" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/select_static_location_btn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/select_point_on_map"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#2D4566"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_map_pin"
                    app:iconTint="#41AEE7" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_general_btn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:text="@string/save_general_settings"
                android:textAllCaps="false"
                android:textColor="#071427"
                android:textStyle="bold"
                app:backgroundTint="#3DDC84"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/scanner_settings_title"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_scanner_label"
                android:textColor="@android:color/white"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/scanner_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:backgroundTint="@android:color/white"
                android:popupBackground="#0B1A2C"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/SantiWayTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/scan_interval_hint"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/interval_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@android:color/white"
                    android:textColorHint="@android:color/white"
                    android:visibility="gone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/SantiWayTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/signal_strength_hint"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/signal_strength_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal|numberSigned"
                    android:textColor="@android:color/white"
                    android:textColorHint="@android:color/white"
                    android:visibility="gone" />
            </com.google.android.material.textfield.TextInputLayout>

            <Switch
                android:id="@+id/enabled_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/enabled_label"
                android:textColor="@android:color/white"
                android:thumbTint="@android:color/white"
                android:trackTint="#FFFFFF"
                android:visibility="gone" />

            <Button
                android:id="@+id/save_scanner_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="#2C4872"
                android:text="@string/save_scanner_settings"
                android:textColor="@android:color/white"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
