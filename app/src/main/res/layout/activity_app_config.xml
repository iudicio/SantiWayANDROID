<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/root_app_config"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B1A2C">

    <androidx.appcompat.widget.Toolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="?attr/actionBarSize"
    android:background="#0B1A2C"
    app:title="@string/app_config_title"
    app:titleTextColor="@android:color/white"
    app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_settings_title"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/server_ipv4_hint"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#172A46"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/server_ip_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:focusable="false"
                android:clickable="false"
                android:longClickable="false"
                android:textColor="@android:color/white"
                android:textColorHint="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/api_key_hint"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#172A46"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/api_key_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:focusable="false"
                android:clickable="false"
                android:longClickable="false"
                android:textColor="@android:color/white"
                android:textColorHint="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/device_name_hint"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#172A46"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/device_scanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@android:color/white"
                android:textColorHint="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/map_points_count_hint"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#172A46"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/map_point_limit_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@android:color/white"
                android:textColorHint="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/language_label"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            app:cardBackgroundColor="#172A46"
            app:cardCornerRadius="12dp"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <Spinner
                    android:id="@+id/language_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"
                    android:background="@android:color/transparent"
                    android:popupBackground="#172A46" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:gravity="center"
                    android:text="@string/spinner_arrow"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:clickable="false"
                    android:focusable="false" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/geolocation_protocol_label"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            app:cardBackgroundColor="#172A46"
            app:cardCornerRadius="12dp"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <Spinner
                    android:id="@+id/protocol_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="12dp"
                    android:paddingEnd="44dp"
                    android:background="@android:color/transparent"
                    android:popupBackground="#172A46" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:gravity="center"
                    android:text="@string/spinner_arrow"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:clickable="false"
                    android:focusable="false" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <Switch
            android:id="@+id/target_detection_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/target_detection_label"
            android:textColor="@android:color/white"
            android:thumbTint="@android:color/white"
            android:trackTint="#FFFFFF"
            android:visibility="gone"/>

        <Switch
            android:id="@+id/static_location_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/use_static_coordinates"
            android:textColor="@android:color/white"
            android:thumbTint="@android:color/white"
            android:trackTint="#FFFFFF" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/latitude_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/static_latitude_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="@android:color/white"
                android:textColorHint="@android:color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/longitude_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/static_longitude_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="@android:color/white"
                android:textColorHint="@android:color/white"
                android:background="@null" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/select_static_location_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="@string/select_point_on_map"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="#172A46"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/save_general_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="@string/save_general_settings"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="#172A46"
            app:cornerRadius="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scanner_settings_title"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_scanner_label"
            android:textColor="@android:color/white"
            android:visibility="gone"/>

        <Spinner
            android:id="@+id/scanner_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/white"
            android:popupBackground="#0B1A2C"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/scan_interval_hint"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/interval_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@android:color/white"
                android:textColorHint="@android:color/white"
                android:background="@null"
                android:visibility="gone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SantiWayTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/signal_strength_hint"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/signal_strength_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textColor="@android:color/white"
                android:textColorHint="@android:color/white"
                android:background="@null"
                android:visibility="gone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <Switch
            android:id="@+id/enabled_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enabled_label"
            android:textColor="@android:color/white"
            android:thumbTint="@android:color/white"
            android:trackTint="#FFFFFF"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/save_scanner_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_scanner_settings"
            android:textColor="@android:color/white"
            android:backgroundTint="#2C4872"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

<!--        <TextView-->
<!--            android:id="@+id/result_text"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="32dp"-->
<!--            android:textSize="12sp"-->
<!--            android:textColor="#AAAAAA"/>-->

    </LinearLayout>
</ScrollView>
</LinearLayout>