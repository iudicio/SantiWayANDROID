<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/action_rename"
        style="@style/FooterActionButton"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_create"
            app:tint="@android:color/white"
            android:contentDescription="@string/content_desc_rename_icon"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rename_action"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_clear"
        style="@style/FooterActionButton"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_block"
            app:tint="@android:color/white"
            android:contentDescription="@string/content_desc_clear_icon"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clear_action"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_grey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_grey"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/grey_action"
            android:textColor="@android:color/white"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_alarm"
        style="@style/FooterActionButton"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_notifications"
            app:tint="#FF6B6B"
            android:contentDescription="@string/content_desc_alarm_icon"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_target_en"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_safe"
        style="@style/FooterActionButton"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_device"
            app:tint="#3DDC84"
            android:contentDescription="@string/content_desc_safe_icon"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_safe_en"
            android:textSize="10sp"
            style="@style/FooterActionText" />
    </LinearLayout>

</LinearLayout>