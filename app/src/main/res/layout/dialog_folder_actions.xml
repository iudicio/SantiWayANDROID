<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_folder_actions_dialog"
    android:orientation="vertical">

    <TextView
        android:id="@+id/folder_actions_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_folder_actions_header"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/folder_action_move_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:text="@string/folder_action_move"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="#172A46"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_folder_move"
            app:iconGravity="textStart"
            app:iconPadding="14dp"
            app:iconTint="#3DDC84"
            app:strokeColor="#2D4566"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/folder_action_rename_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:text="@string/folder_action_rename"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="#172A46"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_folder_rename"
            app:iconGravity="textStart"
            app:iconPadding="14dp"
            app:iconTint="#41AEE7"
            app:strokeColor="#2D4566"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/folder_action_delete_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp"
            android:text="@string/folder_action_delete"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="#4A2030"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_folder_delete"
            app:iconGravity="textStart"
            app:iconPadding="14dp"
            app:iconTint="#FF8A95"
            app:strokeColor="#7A3348"
            app:strokeWidth="1dp" />
    </LinearLayout>
</LinearLayout>
