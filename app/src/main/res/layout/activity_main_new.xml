<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0B1A2C">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0B1A2C"
            app:titleTextColor="@android:color/white">

            <TextView
                android:id="@+id/toolbar_folder_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/default_folder_unified_data"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:clickable="true"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:background="@drawable/folder_title_background" />

            <TextView
                android:id="@+id/scan_timer_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:textColor="@android:color/white" android:textSize="18sp"
                android:textStyle="bold"
                android:text="@string/timer_zero"
                android:visibility="gone" />
        </androidx.appcompat.widget.Toolbar>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_swipe_area"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
            android:id="@+id/time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/time_label_initial" android:textColor="@android:color/white"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

            <GridLayout
                android:id="@+id/scan_buttons_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="32dp"
                android:columnCount="2"
                android:rowCount="3"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/time_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:id="@+id/scan_button_container" android:layout_width="82dp"
                        android:layout_height="82dp">
                        <ImageView android:id="@+id/scan_arrows_icon" android:layout_width="82dp"
                            android:layout_height="82dp" android:layout_gravity="center"
                            android:contentDescription="@string/content_desc_start_pause"
                            android:src="@drawable/ic_scan_arrows" />
                        <ImageButton android:id="@+id/play_pause_button" android:layout_width="52dp"
                            android:layout_height="52dp" android:layout_gravity="center"
                            android:background="@android:color/transparent" android:contentDescription="@string/content_desc_start_pause"
                            android:src="@drawable/ic_play_scan" />
                    </FrameLayout>
                    <TextView style="@style/MainControlLabel" android:text="@string/control_scan" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <ImageButton android:id="@+id/snapshot_button" style="@style/MainControlButton"
                        android:contentDescription="@string/content_desc_snapshot" android:src="@drawable/ic_snapshot_camera" />
                    <TextView style="@style/MainControlLabel" android:text="@string/control_snapshot" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_marginTop="12dp" android:gravity="center" android:orientation="vertical">
                    <ImageButton android:id="@+id/target_detection_button" style="@style/MainControlButton"
                        android:contentDescription="@string/control_alerts" android:src="@drawable/ic_target_bell" />
                    <TextView style="@style/MainControlLabel" android:text="@string/control_alerts" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_marginTop="12dp" android:gravity="center" android:orientation="vertical">
                    <ImageButton android:id="@+id/esp32_button" style="@style/MainControlButton"
                        android:contentDescription="@string/control_esp32" android:src="@drawable/ic_esp32_chip" />
                    <TextView style="@style/MainControlLabel" android:text="@string/control_esp32" />
                </LinearLayout>

            </GridLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/wifi_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#172A46" app:cardCornerRadius="12dp"
                app:contentPadding="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/scan_buttons_container">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="@color/white"
                        android:contentDescription="@string/content_desc_wifi_icon"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="@string/wifi_text"
                        android:textColor="@color/white"
                        android:textSize="24sp" />
                    <TextView
                        android:id="@+id/wifi_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stopped_status"
                        android:textColor="@android:color/white" android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/bluetooth_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#172A46"
                app:cardCornerRadius="12dp"
                app:contentPadding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/wifi_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_bluet"
                        app:tint="@color/white"
                        android:contentDescription="@string/content_desc_bluetooth_icon"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="@string/bluetooth_text"
                        android:textColor="@color/white"
                        android:textSize="24sp" />
                    <TextView
                        android:id="@+id/bluetooth_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stopped_status"
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cellular_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#172A46"
                app:cardCornerRadius="12dp"
                app:contentPadding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bluetooth_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_cell"
                        app:tint="@color/white"
                        android:contentDescription="@string/content_desc_cellular_icon"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="@string/cellular_text"
                        android:textColor="@color/white"
                        android:textSize="24sp" />
                    <TextView
                        android:id="@+id/cellular_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stopped_status"
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/coordinates_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/coordinates_text"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="gone" app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cellular_card" />

            <androidx.cardview.widget.CardView
                android:id="@+id/footer_card_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                app:cardBackgroundColor="#172A46"
                app:cardCornerRadius="0dp"
                app:cardElevation="10dp"
                app:cardPreventCornerOverlap="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/footer_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" >

                    <include layout="@layout/footer_button_layout" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
