<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainControlButton">
        <item name="android:layout_width">82dp</item>
        <item name="android:layout_height">82dp</item>
        <item name="android:background">@drawable/rounded_button_with_stroke</item>
        <item name="android:padding">21dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:elevation">6dp</item>
        <item name="tint">#3DDC84</item>
    </style>

    <style name="MainControlLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Esp32SettingsInput" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorHint">#9FB3C8</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="Esp32SettingsButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">#172A46</item>
        <item name="cornerRadius">12dp</item>
    </style>
    <style name="SantiWayTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#0B1A2C</item>
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/text_input_hint_white</item>
        <item name="android:textColorHint">@color/text_input_hint_white</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

</resources>
